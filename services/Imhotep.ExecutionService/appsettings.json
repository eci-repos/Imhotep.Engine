{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AIProviders": {
    "ActiveProvider": "LocalModel", // Can be toggled to "OpenAI", "AzureOpenAI" or "LocalModel"

    "OpenAI": {
      "ModelId": "gpt-4-turbo",
      "ApiKey": "YOUR_OPENAI_API_KEY"
    },

    "AzureOpenAI": {
      "DeploymentName": "my-gpt4-deployment",
      "Endpoint": "https://my-resource.openai.azure.com/",
      "ApiKey": "YOUR_AZURE_API_KEY"
    },

    "LocalModel": {
      "ModelId": "llama-3",
      "Endpoint": "http://localhost:11434/"
    }
  }
}
